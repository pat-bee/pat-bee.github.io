      <footer class="page-footer">
        <a id="footerArtistLink"
           href="https://www.instagram.com/patbee.music/"
           target="_blank" rel="noopener noreferrer"
           aria-label="Pat Bɇɇ on Instagram (opens in new tab)">Pat Bɇɇ</a>
      </footer>

    </div>
  </main>

  <audio id="audioEl" preload="metadata" playsinline x-webkit-airplay="allow"></audio>

  <script>
    /* ════════════════════════════════════════════════════════════════════════
       SONG_CONFIG — single source of truth.
       CDN filenames follow Pat-Bee_ convention — confirm before deploy.
    ════════════════════════════════════════════════════════════════════════ */
    const SONG_CONFIG = {
      title:         "PFuture33",
      artist:        "Pat Bɇɇ",
      album:         "index_album",
      slug:          "pfuture33",
      cdnBase:       "https://pub-8ca7a487f9234c669dfad0530698bfe0.r2.dev",
      pageUrl:       "https://pat-bee.github.io/album/pfuture33/",
      artistUrl:     "https://www.instagram.com/patbee.music/",
      artistLabel:   "Pat Bɇɇ on Instagram",
      albumUrl:      "../",
      albumLabel:    "Album-Index",
      remixEndpoint: "",
      artFile:       "pat-bee_pfuture33.png",
      flacFile:      "Pat-Bee_PFuture33.flac",   /* download only */
      fallbackFile:  "Pat-Bee_PFuture33.m4a",    /* playback */
    };

    const CDN           = SONG_CONFIG.cdnBase;
    const ALBUM_ART_URL = CDN + "/" + SONG_CONFIG.artFile;

    function buildArtistUrl(source) {
      return SONG_CONFIG.artistUrl
        + "?utm_source=" + source
        + "&utm_medium=songpage"
        + "&utm_campaign=" + SONG_CONFIG.slug;
    }

    const album = {
      title:      SONG_CONFIG.album,
      artist:     SONG_CONFIG.artist,
      artworkUrl: ALBUM_ART_URL,
      tracks: [
        {
          title:    SONG_CONFIG.title,
          duration: "—",
          src:      CDN + "/" + SONG_CONFIG.fallbackFile,
          flac:     CDN + "/" + SONG_CONFIG.flacFile,
        }
      ]
    };

    /* ════════════════════════════════════════════════════════════════════════
       M4A STREAMING ENGINE — same as OpStylo codebase
    ════════════════════════════════════════════════════════════════════════ */
    const ICON_DARK  = "data:image/png;base64,";
    const ICON_LIGHT = ICON_DARK;

    /* DOM refs */
    const audio     = document.getElementById("audioEl");
    const playBtn   = document.getElementById("playBtn");
    const prevBtn   = document.getElementById("prevBtn");
    const nextBtn   = document.getElementById("nextBtn");
    const repeatBtn = document.getElementById("repeatBtn");
    const progBar   = document.getElementById("progBar");
    const curTimeEl = document.getElementById("curTime");
    const durTimeEl = document.getElementById("durTime");
    const bufFill   = document.getElementById("bufFill");
    const npTitle   = document.getElementById("npTitle");
    const fmtBadge  = document.getElementById("fmtBadge");
    const liveDot   = document.getElementById("liveDot");
    const errLine   = document.getElementById("errLine");
    const artWrap   = document.getElementById("artWrap");
    const trackList = document.getElementById("trackList");

    /* State */
    let currentIndex = 0, isLoaded = false, usedFallback = false;
    let isSeeking = false, repeatMode = "off";
    let wakeLock = null;

    /* Wake lock */
    async function acquireWake() {
      if (!("wakeLock" in navigator)) return;
      try {
        wakeLock = await navigator.wakeLock.request("screen");
        wakeLock.addEventListener("release", () => { if (!audio.paused) acquireWake(); });
      } catch (_) {}
    }
    async function dropWake() {
      if (wakeLock) { try { await wakeLock.release(); } catch (_) {} wakeLock = null; }
    }
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible" && !audio.paused) acquireWake();
    });

    /* Load M4A (tryFlac=true falls back to FLAC on error) */
    function loadTrack(idx, tryFlac = false) {
      const si = Math.max(0, Math.min(idx, album.tracks.length - 1));
      const tr = album.tracks[si];
      currentIndex = si; isLoaded = false; usedFallback = tryFlac;
      npTitle.textContent = tr.title;
      if (fmtBadge) fmtBadge.textContent = tryFlac ? "FLAC" : "M4A";
      clearErr(); updateTrackUI(); updateMediaSession(tr);
      audio.src = tryFlac ? tr.flac : tr.src;
      audio.preload = "auto";
      audio.load();
    }

    function showLoadingState() {
      playBtn.classList.remove("is-armed");
      playBtn.classList.add("is-loading-text");
      playBtn.textContent = "LOADING";
      playBtn.setAttribute("aria-label", "Loading audio");
      bufFill.classList.add("loading");
      bufFill.style.background = "rgba(184,255,0,0.4)";
    }

    function armButton() {
      playBtn.classList.remove("is-loading", "is-loading-text");
      playBtn.classList.add("is-armed");
      playBtn.textContent = "PLAY";
      playBtn.setAttribute("aria-label", "Play " + album.tracks[currentIndex].title + " — ready");
      bufFill.classList.remove("loading");
      bufFill.style.background = "";
      bufFill.style.width = "0%";
    }

    audio.addEventListener("canplay", () => {
      if (!isLoaded) { isLoaded = true; armButton(); }
    });

    async function togglePlay() {
      if (!isLoaded) { loadTrack(currentIndex, false); showLoadingState(); return; }
      if (audio.paused) {
        playBtn.classList.remove("is-armed");
        try { await audio.play(); setPlayState(true); await acquireWake(); }
        catch (_) { showErr("// Could not start — try again"); }
      } else { audio.pause(); setPlayState(false); dropWake(); }
    }

    function playPrev() {
      if (audio.currentTime > 3 && isLoaded) { audio.currentTime = 0; return; }
      loadTrack(Math.max(0, currentIndex - 1), false); showLoadingState();
    }
    function playNext() {
      if (currentIndex < album.tracks.length - 1) {
        loadTrack(currentIndex + 1, false); showLoadingState();
      } else if (repeatMode === "album") {
        loadTrack(0, false); showLoadingState();
      } else { setPlayState(false); dropWake(); }
    }

    function setPlayState(on) {
      playBtn.classList.remove("is-loading-text", "is-armed", "is-loading");
      playBtn.textContent = on ? "PAUSE" : "PLAY";
      playBtn.setAttribute("aria-label",
        on ? "Pause " + album.tracks[currentIndex]?.title
           : "Play "  + album.tracks[currentIndex]?.title);
      artWrap.classList.toggle("is-playing", on);
      liveDot.classList.toggle("active", on);
      setMediaPlayState(on ? "playing" : "paused");
      updateTrackUI();
    }

    function cycleRepeat() {
      const modes = album.tracks.length === 1 ? ["off","song"] : ["off","song","album"];
      repeatMode = modes[(modes.indexOf(repeatMode) + 1) % modes.length];
      const m = { off:{l:"↺ Repeat: Off",p:"false"}, song:{l:"↺ Repeat: Song",p:"true"}, album:{l:"↺ Repeat: Album",p:"true"} };
      repeatBtn.textContent = m[repeatMode].l; repeatBtn.dataset.mode = repeatMode;
      repeatBtn.setAttribute("aria-label", m[repeatMode].l + ". Press to cycle.");
      repeatBtn.setAttribute("aria-pressed", m[repeatMode].p);
    }

    /* Audio events */
    audio.addEventListener("ended", () => {
      if (repeatMode === "song") { audio.currentTime = 0; audio.play().catch(() => {}); return; }
      playNext();
    });
    audio.addEventListener("playing", () => { bufFill.classList.remove("loading"); bufFill.style.background = ""; setPlayState(true); });
    audio.addEventListener("waiting", () => { bufFill.classList.add("loading"); bufFill.style.background = "rgba(184,255,0,0.3)"; });
    audio.addEventListener("pause",   () => { artWrap.classList.remove("is-playing"); liveDot.classList.remove("active"); updateTrackUI(); });
    audio.addEventListener("play",    () => updateTrackUI());
    audio.addEventListener("error",   () => {
      if (!usedFallback) { loadTrack(currentIndex, true); return; }
      isLoaded = false;
      playBtn.classList.remove("is-loading-text", "is-armed", "is-loading");
      playBtn.textContent = "PLAY";
      showErr("// Signal lost — check connection");
    });
    let stallTimer;
    audio.addEventListener("stalled", () => {
      clearTimeout(stallTimer);
      stallTimer = setTimeout(() => { if (!audio.paused) audio.play().catch(() => {}); }, 1200);
    });
    audio.addEventListener("progress", () => clearTimeout(stallTimer));
    audio.addEventListener("playing",  () => clearTimeout(stallTimer));

    /* Progress */
    const fmt = s => !Number.isFinite(s) || s < 0 ? "0:00" : Math.floor(s / 60) + ":" + String(Math.floor(s % 60)).padStart(2, "0");
    audio.addEventListener("loadedmetadata", () => {
      durTimeEl.textContent = fmt(audio.duration);
      progBar.setAttribute("aria-valuemax", Math.floor(audio.duration));
      const d = trackList.querySelectorAll(".track-dur");
      if (d[currentIndex]) d[currentIndex].textContent = fmt(audio.duration);
    });
    audio.addEventListener("timeupdate", () => {
      if (isSeeking || !Number.isFinite(audio.duration) || !audio.duration) return;
      progBar.value = (audio.currentTime / audio.duration) * 100;
      progBar.setAttribute("aria-valuenow", Math.floor(audio.currentTime));
      progBar.setAttribute("aria-valuetext", fmt(audio.currentTime) + " of " + fmt(audio.duration));
      curTimeEl.textContent = fmt(audio.currentTime);
      updateMediaPosition();
    });
    audio.addEventListener("progress", () => {
      if (!audio.duration || !audio.buffered.length) return;
      bufFill.style.width = (audio.buffered.end(audio.buffered.length - 1) / audio.duration) * 100 + "%";
    });
    progBar.addEventListener("mousedown",  () => isSeeking = true);
    progBar.addEventListener("touchstart", () => isSeeking = true, { passive: true });
    progBar.addEventListener("input", () => {
      if (audio.duration) { const t = (progBar.value / 100) * audio.duration; curTimeEl.textContent = fmt(t); progBar.setAttribute("aria-valuetext", fmt(t) + " of " + fmt(audio.duration)); }
    });
    progBar.addEventListener("change", () => { if (audio.duration) audio.currentTime = (progBar.value / 100) * audio.duration; isSeeking = false; });
    progBar.addEventListener("mouseup",  () => isSeeking = false);
    progBar.addEventListener("touchend", () => isSeeking = false);

    /* Media session */
    function updateMediaSession(tr) {
      if (!("mediaSession" in navigator)) return;
      navigator.mediaSession.metadata = new MediaMetadata({
        title: tr.title, artist: album.artist, album: album.title,
        artwork: [{ src: album.artworkUrl, sizes: "512x512", type: "image/png" }]
      });
      const h = {
        play: async () => { await togglePlay(); },
        pause: () => { audio.pause(); setPlayState(false); dropWake(); },
        previoustrack: playPrev, nexttrack: playNext,
        seekbackward: e => { audio.currentTime = Math.max(0, audio.currentTime - (e.seekOffset || 10)); },
        seekforward:  e => { audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + (e.seekOffset || 10)); },
        seekto: e => { if (e.fastSeek && "fastSeek" in audio) audio.fastSeek(e.seekTime); else audio.currentTime = e.seekTime; }
      };
      for (const [a, fn] of Object.entries(h)) { try { navigator.mediaSession.setActionHandler(a, fn); } catch (_) {} }
    }
    function setMediaPlayState(s) { if ("mediaSession" in navigator) navigator.mediaSession.playbackState = s; }
    function updateMediaPosition() {
      if (!("mediaSession" in navigator) || !Number.isFinite(audio.duration)) return;
      try { navigator.mediaSession.setPositionState({ duration: audio.duration, playbackRate: audio.playbackRate, position: audio.currentTime }); } catch (_) {}
    }

    /* Keyboard */
    document.addEventListener("keydown", e => {
      if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
      switch (e.key) {
        case " ": case "MediaPlayPause": e.preventDefault(); togglePlay(); break;
        case "ArrowRight": e.preventDefault(); audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + 10); break;
        case "ArrowLeft":  e.preventDefault(); audio.currentTime = Math.max(0, audio.currentTime - 10); break;
        case "ArrowUp":    e.preventDefault(); audio.volume = Math.min(1, audio.volume + 0.05); break;
        case "ArrowDown":  e.preventDefault(); audio.volume = Math.max(0, audio.volume - 0.05); break;
        case "n": case "N": case "MediaTrackNext":     playNext(); break;
        case "p": case "P": case "MediaTrackPrevious": playPrev(); break;
        case "r": case "R": cycleRepeat(); break;
        case "m": case "M": audio.muted = !audio.muted; break;
      }
    });

    /* Share strip */
    function initShareStrip() {
      const btnNative = document.getElementById("btnNativeShare");
      const btnCopy   = document.getElementById("btnCopyLink");
      const shareData = { title: SONG_CONFIG.title + " — " + SONG_CONFIG.artist, text: "Listen to " + SONG_CONFIG.title + " by " + SONG_CONFIG.artist, url: SONG_CONFIG.pageUrl };
      if (navigator.share) { btnNative.addEventListener("click", () => { navigator.share(shareData).catch(() => {}); }); } else { btnNative.classList.add("hidden"); }
      if (navigator.clipboard) {
        btnCopy.addEventListener("click", () => {
          navigator.clipboard.writeText(SONG_CONFIG.pageUrl).then(() => { btnCopy.classList.add("copied"); setTimeout(() => btnCopy.classList.remove("copied"), 2000); }).catch(() => {});
        });
      } else { btnCopy.classList.add("hidden"); }
    }

    /* Masthead — album up-link · artist link (same logic as OpStylo) */
    function initMasthead() {
      const eyebrow = document.getElementById("mastheadEyebrow");
      if (eyebrow) {
        const albumPart  = SONG_CONFIG.albumUrl ? '<a href="' + SONG_CONFIG.albumUrl + '">' + SONG_CONFIG.albumLabel + '</a>' : '';
        const artistPart = '<a href="' + buildArtistUrl("header") + '" target="_blank" rel="noopener noreferrer" aria-label="' + SONG_CONFIG.artistLabel + ' (opens in new tab)">' + SONG_CONFIG.artist + '</a>';
        eyebrow.innerHTML = albumPart ? albumPart + ' · ' + artistPart : artistPart;
      }
    }
    function initFooter() {
      const link = document.getElementById("footerArtistLink");
      if (link) { link.href = buildArtistUrl("footer"); link.textContent = SONG_CONFIG.artist; link.setAttribute("aria-label", SONG_CONFIG.artistLabel + " (opens in new tab)"); }
    }

    /* Track list */
    function updateTrackUI() {
      trackList.querySelectorAll(".track-btn").forEach((btn, i) => {
        const cur = i === currentIndex && isLoaded;
        btn.setAttribute("aria-current", cur ? "true" : "false");
        btn.classList.toggle("is-playing", cur && !audio.paused);
        if (cur) btn.setAttribute("aria-label", "Track " + (i + 1) + ": " + album.tracks[i].title + " — " + (audio.paused ? "paused" : "now playing"));
      });
    }

    function renderTracks() {
      trackList.innerHTML = "";
      const el = document.getElementById("trackCount");
      if (el) el.textContent = album.tracks.length + " Recording" + (album.tracks.length !== 1 ? "s" : "");

      album.tracks.forEach((tr, i) => {
        const li = document.createElement("li"), btn = document.createElement("button");
        btn.className = "track-btn"; btn.type = "button";
        btn.setAttribute("aria-current", "false");
        btn.setAttribute("aria-label", "Track " + (i + 1) + ": " + tr.title + " by " + album.artist);
        btn.innerHTML =
          '<span class="track-num" aria-hidden="true">' + String(i + 1).padStart(2, "0") + '</span>' +
          '<span class="track-info-col"><span class="track-title-text">' + tr.title + '</span>' +
          '<span class="track-meta-text">' + album.artist + '</span></span>' +
          '<span class="track-dur" aria-label="Duration: ' + tr.duration + '">' + tr.duration + '</span>';
        btn.addEventListener("click", () => { loadTrack(i, false); showLoadingState(); });
        li.appendChild(btn); trackList.appendChild(li);
      });

      /* Remix row */
      const ACCEPTED_EXTS = ["m4a","flac","wav","mp3"];
      const ACCEPTED_MIME = ["audio/mp4","audio/flac","audio/x-flac","audio/wav","audio/x-wav","audio/mpeg"];
      const rl = document.createElement("li");
      rl.innerHTML =
        '<div class="remix-row" role="button" tabindex="0" aria-label="Submit a remix">' +
        '<input class="remix-file-input" type="file" accept=".m4a,.flac,.wav,.mp3,audio/mp4,audio/flac,audio/x-flac,audio/wav,audio/mpeg" id="remixFileInput"/>' +
        '<div class="remix-icon-cell" aria-hidden="true"><img src="' + ICON_DARK + '" alt=""/></div>' +
        '<div class="remix-info"><span class="remix-title">Submit a Remix</span><span class="remix-sub">m4a · flac · wav · mp3</span></div>' +
        '<div class="remix-status" aria-live="polite" id="remixStatus">+ Add</div></div>';
      trackList.appendChild(rl);
      const toast = document.createElement("p");
      toast.className = "upload-toast"; toast.setAttribute("aria-live", "polite");
      trackList.parentElement.appendChild(toast);

      document.getElementById("remixFileInput").addEventListener("change", function () {
        const file = this.files[0]; if (!file) return;
        const cta = document.getElementById("remixStatus");
        const ext = file.name.split(".").pop().toLowerCase();
        const mime = (file.type || "").toLowerCase();
        if (!ACCEPTED_EXTS.includes(ext) || (!ACCEPTED_MIME.some(m => mime.startsWith(m)) && mime !== "")) {
          cta.textContent = "REJECTED"; toast.textContent = "// Only .m4a, .flac, .wav, and .mp3 accepted."; toast.classList.add("show"); return;
        }
        cta.textContent = "✓ Received";
        toast.textContent = "// Received: " + file.name + " (" + (file.size / 1024 / 1024).toFixed(2) + " MB)";
        toast.classList.add("show");
        if (SONG_CONFIG.remixEndpoint) {
          const fd = new FormData(); fd.append("remix", file); fd.append("song", SONG_CONFIG.slug);
          fetch(SONG_CONFIG.remixEndpoint, { method: "POST", body: fd }).catch(err => { toast.textContent += " [Upload failed]"; console.error(err); });
        }
      });

      if (album.tracks.length === 1) { prevBtn.style.display = "none"; nextBtn.style.display = "none"; }
    }

    function showErr(m) { errLine.textContent = m; errLine.classList.add("show"); }
    function clearErr()  { errLine.textContent = ""; errLine.classList.remove("show"); }

    playBtn.addEventListener("click",   togglePlay);
    prevBtn.addEventListener("click",   playPrev);
    nextBtn.addEventListener("click",   playNext);
    repeatBtn.addEventListener("click", cycleRepeat);

    /* Init */
    function init() {
      document.getElementById("albumArtImg").src = ALBUM_ART_URL;
      const dlBtn = document.getElementById("downloadFlac");
      if (dlBtn) dlBtn.href = album.tracks[0].flac;
      if (fmtBadge) { fmtBadge.textContent = "M4A"; fmtBadge.className = "badge badge-fmt"; }
      const fmtDot = document.getElementById("fmtDot");
      if (fmtDot) { fmtDot.classList.add("is-lossy"); fmtDot.title = "AAC M4A"; }
      initMasthead();
      initFooter();
      initShareStrip();
      renderTracks();
      updateMediaSession(album.tracks[0]);
      setPlayState(false);
    }

    init();
  </script>
</body>
</html>
