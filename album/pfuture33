  <!--
    Orbitron — designed explicitly for digital displays and HUDs.
    Geometric, uppercase, zero-ambiguity letterforms. The default
    choice when the brief is "looks like a terminal screen".
    Used for all display titles: masthead, now-playing, track names, play button.

    Courier Prime — typewriter monospace for all UI chrome.
  -->
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet" />

  <style>
    /*
    ══════════════════════════════════════════════════════════════
    PFUTURE33 — Terminal / Digital Display design system
    ──────────────────────────────────────────────────────────────
    Two colours. No gradients. No softening.

    #1B0C2E  Screen void — deep purple ground.
    #B8FF00  Phosphor signal — electric lime. Every active element.
             Boxes, borders, text, buttons, dots.
             If it matters, it's lime.

    The aesthetic is the reference image:
      dark field → bright lime selection box → dark text inside.
    That inverted-box pattern IS the play button.

    TYPOGRAPHY:
      Orbitron 700/900   — all display/title text. Digital HUD.
      Courier Prime 400  — all UI chrome. Status lines.
    ══════════════════════════════════════════════════════════════
    */
    :root {
      /* Screen void — deep purple */
      --canvas:        #1B0C2E;
      --bg:            #1B0C2E;
      --bg-panel:      #200F36;
      --bg-raised:     #27143F;
      --bg-inset:      #150A24;

      /* Phosphor — electric lime */
      --lime:          #B8FF00;
      --lime-bright:   #CCFF40;
      --lime-dim:      #7EAF00;
      --lime-faint:    rgba(184,255,0,0.08);
      --lime-pale:     rgba(184,255,0,0.16);
      --lime-border:   rgba(184,255,0,0.38);
      --lime-text:     #1B0C2E;  /* dark purple on lime box */

      /* Aliases that map to the template var names */
      --grid:          #B8FF00;
      --grid-mid:      #7EAF00;
      --grid-dim:      #527300;
      --ink:           #B8FF00;
      --ink-mid:       #8ACC00;
      --ink-dim:       #527300;
      --ink-ghost:     rgba(184,255,0,0.05);

      /* Primary — play button, active track, focus */
      --red:           #B8FF00;
      --red-bright:    #CCFF40;
      --red-dim:       #7EAF00;
      --red-faint:     rgba(184,255,0,0.08);
      --red-pale:      rgba(184,255,0,0.16);
      --red-border:    rgba(184,255,0,0.42);
      --red-text:      #1B0C2E;

      /* Secondary — seek thumb, live dot, buffer bar */
      --blue:          #B8FF00;
      --blue-bright:   #CCFF40;
      --blue-dim:      #7EAF00;
      --blue-faint:    rgba(184,255,0,0.08);
      --blue-border:   rgba(184,255,0,0.30);

      /* Tertiary — remix row */
      --green:         #7EAF00;
      --green-bright:  #B8FF00;
      --green-dim:     #527300;
      --green-faint:   rgba(184,255,0,0.06);
      --green-border:  rgba(184,255,0,0.25);

      /* Borders — lime at varying opacity */
      --border:        rgba(184,255,0,0.16);
      --border-mid:    rgba(184,255,0,0.30);
      --border-strong: rgba(184,255,0,0.55);

      --focus-ring:    #B8FF00;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .skip-link {
      position: absolute; top: -100%; left: 12px; z-index: 99999;
      background: var(--lime); color: var(--lime-text);
      padding: 8px 18px; font-family: 'Courier Prime', monospace;
      font-size: 0.8rem; letter-spacing: 0.08em;
      text-decoration: none; transition: top 200ms;
    }
    .skip-link:focus { top: 0; }
    :focus-visible { outline: 2px solid var(--focus-ring); outline-offset: 3px; }

    html {
      background: var(--bg);
      color: var(--ink);
      font-family: 'Courier Prime', 'Courier New', monospace;
      min-height: 100%;
      -webkit-text-size-adjust: 100%;
    }

    /* Body: CRT scanlines over deep purple void.
       Every 3px: two void, one hairline phosphor.
       Subtle — texture without noise.                */
    body {
      min-height: 100vh;
      background-color: #1B0C2E;
      background:
        repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(184,255,0,0.022) 2px,
          rgba(184,255,0,0.022) 3px
        ),
        #1B0C2E;
      position: relative; overflow-x: hidden;
    }

    /* Vignette — phosphor dims at screen edges */
    body::before {
      content: ""; position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse at 50% 40%, transparent 55%, rgba(8,2,16,0.7) 100%);
    }

    button { font-family: 'Courier Prime', monospace; color: inherit; cursor: pointer; }

    .page-shell {
      position: relative; z-index: 1; min-height: 100vh;
      display: flex; flex-direction: column; align-items: center;
      padding: 40px 20px 64px;
    }
    .inner { width: 100%; max-width: 880px; }

    /* ── MASTHEAD ────────────────────────────────────────────────────────
       Lime left bar = signal. Dark panel = screen.
       Eyebrow rendered by initMasthead() — album up-link · artist link.
    ──────────────────────────────────────────────────────────────────────── */
    .masthead {
      position: relative;
      padding: 22px 28px 18px 32px;
      background: var(--bg-raised);
      border: 1px solid var(--border-mid);
      border-bottom: 2px solid var(--lime);
      border-left: 5px solid var(--lime);
      overflow: hidden;
    }
    /* Subtle lime right accent */
    .masthead::after {
      content: "";
      position: absolute; top: 0; right: 0;
      width: 3px; height: 100%;
      background: var(--lime);
      opacity: 0.4;
      pointer-events: none;
    }

    .masthead-eyebrow {
      font-family: 'Courier Prime', monospace;
      font-size: 0.52rem; letter-spacing: 0.36em;
      text-transform: uppercase; color: var(--ink-dim); margin-bottom: 8px;
    }
    .masthead-eyebrow a {
      color: var(--ink-dim); text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: color 140ms, border-color 140ms;
    }
    .masthead-eyebrow a:hover { color: var(--lime); border-bottom-color: var(--lime-border); }

    .masthead-titles { min-width: 0; overflow: hidden; container-type: inline-size; }

    /* Orbitron — digital HUD display. Uppercase locked. */
    .masthead-title {
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: clamp(1.8rem, 11cqi, 5.2rem);
      white-space: nowrap; overflow: hidden; text-overflow: clip;
      line-height: 1.05;
      padding-bottom: 0.06em;
      color: var(--lime);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .masthead-sub {
      margin-top: 8px; font-family: 'Courier Prime', monospace;
      font-size: 0.54rem; letter-spacing: 0.30em;
      text-transform: uppercase; color: var(--ink-dim);
    }

    /* ── MAIN GRID ──────────────────────────────────────────────────────── */
    .main-grid {
      display: grid; grid-template-columns: minmax(210px, 340px) 1fr;
      border: 1px solid var(--border-mid); border-top: none;
      background: var(--bg-panel);
    }

    .col-art { border-right: 1px solid var(--border-mid); }
    .col-player { padding: 22px; display: flex; flex-direction: column; gap: 14px; min-width: 0; }

    /* ── ALBUM ART ───────────────────────────────────────────────────────── */
    .art-wrap {
      position: relative; width: 100%; aspect-ratio: 1 / 1;
      overflow: hidden; background: var(--bg-inset);
      display: block;
      transition: box-shadow 600ms;
    }
    .art-wrap.is-playing {
      /* Lime glow during playback — signal active */
      box-shadow: inset 0 0 0 2px var(--lime), 0 0 24px rgba(184,255,0,0.2);
    }
    .art-wrap img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
      display: block; position: relative; z-index: 2;
      transition: filter 600ms;
    }
    /* Phosphor tint while playing — slight lime cast */
    .art-wrap.is-playing img {
      filter: brightness(1.05) saturate(0.9) hue-rotate(-5deg);
    }

    /* EQ bars — lime phosphor */
    .eq-overlay {
      position: absolute; bottom: 0; left: 0; right: 0; height: 20%;
      display: flex; align-items: flex-end; gap: 2px; padding: 0 10%;
      opacity: 0; transition: opacity 600ms; z-index: 5;
    }
    .art-wrap.is-playing .eq-overlay { opacity: 1; }
    .eq-b { flex: 1; min-height: 2px; background: var(--lime); animation: vu-bar 0.55s ease infinite alternate; }
    .eq-b:nth-child(odd)  { background: var(--lime); }
    .eq-b:nth-child(even) { background: rgba(184,255,0,0.55); }
    .eq-b:nth-child(1){animation-delay:0.00s} .eq-b:nth-child(2){animation-delay:0.09s}
    .eq-b:nth-child(3){animation-delay:0.18s} .eq-b:nth-child(4){animation-delay:0.05s}
    .eq-b:nth-child(5){animation-delay:0.14s} .eq-b:nth-child(6){animation-delay:0.23s}
    .eq-b:nth-child(7){animation-delay:0.07s} .eq-b:nth-child(8){animation-delay:0.16s}
    @keyframes vu-bar { from { height: 4%; } to { height: 80%; } }

    /* ── NOW PLAYING ────────────────────────────────────────────────────── */
    .np-label {
      font-family: 'Courier Prime', monospace;
      font-size: 0.5rem; letter-spacing: 0.36em;
      text-transform: uppercase; color: var(--ink-dim); margin-bottom: 4px;
    }
    .np-title {
      font-family: 'Orbitron', sans-serif; font-weight: 700;
      font-size: 1.3rem; line-height: 1.1;
      color: var(--lime); word-break: break-word;
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .np-meta { display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap; align-items: center; }

    /* Lime dot — phosphor indicator */
    .live-dot {
      display: inline-block; width: 8px; height: 8px;
      background: transparent; border: 1px solid var(--border-mid);
      flex-shrink: 0; transition: all 200ms;
    }
    .live-dot.active {
      background: var(--lime); border-color: var(--lime);
      box-shadow: 0 0 6px var(--lime);
      animation: phosphor-blink 1.2s ease-in-out infinite;
    }
    @keyframes phosphor-blink { 0%,100%{opacity:1;box-shadow:0 0 6px var(--lime)} 50%{opacity:0.3;box-shadow:none} }

    .fmt-dot {
      display: inline-block; width: 8px; height: 8px;
      background: var(--ink-ghost); border: 1px solid var(--border);
      flex-shrink: 0; transition: all 300ms;
    }
    .fmt-dot.is-lossless { background: var(--lime); border-color: var(--lime-dim); box-shadow: 0 0 4px var(--lime-border); }
    .fmt-dot.is-lossy    { background: var(--lime-dim); border-color: var(--lime-dim); }

    .badge {
      font-family: 'Courier Prime', monospace;
      font-size: 0.5rem; letter-spacing: 0.12em; text-transform: uppercase;
      padding: 2px 7px; border: 1px solid var(--border); color: var(--ink-dim);
    }
    .badge-flac { border-color: var(--lime-border); color: var(--lime); }

    /* Download badge — lime box, dark text (matches image's selection aesthetic) */
    .badge-download {
      border: 1px solid var(--lime);
      background: var(--lime); color: var(--lime-text);
      text-decoration: none; cursor: pointer;
      transition: background 120ms, box-shadow 120ms;
    }
    .badge-download:hover {
      background: var(--lime-bright);
      box-shadow: 0 0 8px var(--lime-border);
    }

    /* Buffer bar */
    .buf-wrap { width: 100%; height: 2px; background: var(--ink-ghost); }
    .buf-fill { height: 100%; background: var(--lime-dim); width: 0%; transition: width 400ms; }
    .buf-fill.loading { animation: buf-flicker 1.0s ease-in-out infinite; }
    @keyframes buf-flicker { 0%,100%{opacity:0.2} 50%{opacity:0.9} }

    /* Seek bar */
    .prog-row {
      display: grid; grid-template-columns: 46px 1fr 46px;
      gap: 8px; align-items: center;
      font-family: 'Courier Prime', monospace; font-size: 0.64rem;
      color: var(--ink-dim); font-variant-numeric: tabular-nums;
    }
    .prog-bar {
      appearance: none; width: 100%; height: 4px;
      background: var(--lime-faint);
      border: 1px solid var(--border); border-radius: 0; cursor: pointer;
    }
    .prog-bar::-webkit-slider-thumb {
      appearance: none; width: 10px; height: 20px;
      background: var(--lime); border: none; border-radius: 0; cursor: pointer;
    }
    .prog-bar::-moz-range-thumb {
      width: 10px; height: 20px;
      background: var(--lime); border: none; border-radius: 0; cursor: pointer;
    }

    /* ── CONTROLS ──────────────────────────────────────────────────────── */
    .controls { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

    .ctrl-btn {
      border: 1px solid var(--border-mid); background: transparent;
      color: var(--ink-dim); font-family: 'Courier Prime', monospace;
      font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 0 14px; min-height: 38px;
      transition: border-color 120ms, color 120ms, background 120ms, transform 80ms;
      position: relative; overflow: hidden;
    }
    .ctrl-btn:hover { border-color: var(--lime); color: var(--lime); background: var(--lime-faint); }
    .ctrl-btn:active { transform: translate(1px,1px); }

    /* ── PLAY BUTTON — THE LIME BOX ──────────────────────────────────────
       Directly from the reference image: bright lime fill, dark text.
       This IS the "selected item" box from that terminal display.
       State 2 (armed): larger glow differentiates from State 1.
    ──────────────────────────────────────────────────────────────────────── */
    .play-btn {
      min-width: 136px; min-height: 52px;
      font-family: 'Orbitron', sans-serif;
      font-weight: 900;
      font-size: 1.1rem; letter-spacing: 0.12em;
      text-transform: uppercase;
      background: var(--lime);
      color: var(--lime-text);
      border: none;
      box-shadow: 0 0 0 1px var(--lime), 2px 2px 0 var(--lime-dim);
    }
    .play-btn:hover {
      background: var(--lime-bright);
      box-shadow: 0 0 12px var(--lime-border), 0 0 0 1px var(--lime);
    }
    .play-btn:active {
      transform: translate(2px, 2px);
      box-shadow: 0 0 0 1px var(--lime);
    }
    /* Loading: dim the box, monospace label, pulse */
    .play-btn.is-loading-text {
      font-family: 'Courier Prime', monospace;
      font-weight: 400;
      font-size: 0.78rem; letter-spacing: 0.08em;
      background: var(--lime-faint); color: var(--lime);
      box-shadow: 0 0 0 1px var(--lime-dim);
      animation: loading-pulse 1.6s ease-in-out infinite;
    }
    @keyframes loading-pulse { 0%,100%{opacity:0.45} 50%{opacity:1} }

    /* State 2 — Armed: full lime box + outer glow — signal locked */
    .play-btn.is-armed {
      background: var(--lime);
      color: var(--lime-text);
      box-shadow: 0 0 0 1px var(--lime), 0 0 16px var(--lime-border), 2px 2px 0 var(--lime-dim);
    }

    .play-btn.is-loading { background: var(--bg-raised); border: 1px solid var(--border-mid); cursor: wait; box-shadow: none; }
    .play-btn.is-loading::after {
      content: ""; position: absolute; top:50%; left:50%;
      width: 14px; height: 14px;
      border: 2px solid var(--lime-faint); border-top-color: var(--lime);
      border-radius: 50%; transform: translate(-50%,-50%);
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: translate(-50%,-50%) rotate(360deg); } }

    .repeat-btn { min-width: 130px; font-size: 0.6rem; }
    .repeat-btn[data-mode="song"]  { border-color: var(--lime-border); color: var(--lime); }
    .repeat-btn[data-mode="album"] { border-style: dashed; }

    .kbd-row { display: flex; gap: 10px; flex-wrap: wrap; }
    .kbd-hint { font-size: 0.48rem; color: var(--ink-dim); text-transform: uppercase; letter-spacing: 0.06em; }
    kbd {
      display: inline-block; padding: 1px 5px; border: 1px solid var(--border-mid);
      font-size: 0.48rem; font-family: inherit; color: var(--lime); background: var(--bg-inset);
    }

    .status-line { font-family: 'Courier Prime', monospace; font-size: 0.52rem; color: var(--ink-dim); line-height: 1.6; letter-spacing: 0.04em; }
    .err-line { font-family: 'Courier Prime', monospace; font-size: 0.6rem; color: var(--lime); display: none; line-height: 1.4; border-left: 2px solid var(--lime-border); padding-left: 8px; }
    .err-line.show { display: block; }

    /* ── PLAYLIST ────────────────────────────────────────────────────────── */
    .playlist-section {
      border: 1px solid var(--border-mid); border-top: none; background: var(--bg-panel);
    }
    .playlist-header {
      padding: 8px 20px; border-bottom: 1px solid var(--border-mid);
      font-family: 'Courier Prime', monospace; font-size: 0.48rem;
      letter-spacing: 0.28em; text-transform: uppercase; color: var(--ink-dim);
      display: flex; justify-content: space-between; align-items: center;
      border-left: 3px solid var(--lime-dim);
    }
    .playlist-header::before {
      content: "Signal Log";
      font-family: 'Orbitron', sans-serif; font-weight: 400;
      font-size: 0.62rem; color: rgba(184,255,0,0.18); letter-spacing: 0.08em;
    }

    .track-list { list-style: none; }
    .track-btn, .remix-row {
      width: 100%; display: grid; grid-template-columns: 52px 1fr auto;
      align-items: stretch; text-align: left;
      border: none; border-bottom: 1px solid var(--border); transition: background 80ms;
    }
    .track-list li:last-child .track-btn,
    .track-list li:last-child .remix-row { border-bottom: none; }
    .track-btn { background: transparent; cursor: pointer; }
    .track-btn:hover { background: var(--lime-faint); }

    /* Active track: lime left bar + lime-washed background */
    .track-btn[aria-current="true"] { background: var(--lime-faint); box-shadow: inset 3px 0 0 var(--lime); }
    .track-btn[aria-current="true"] .track-num { color: var(--lime); }
    .track-btn[aria-current="true"].is-playing .track-num { animation: phosphor-blink 1.2s ease-in-out infinite; }

    .track-num {
      display: flex; align-items: center; justify-content: center;
      padding: 16px 0; border-right: 1px solid var(--border);
      font-family: 'Courier Prime', monospace;
      font-size: 0.88rem; letter-spacing: 0.06em; color: var(--ink-dim); min-width: 52px;
    }
    .track-info-col { padding: 13px 16px; display: flex; flex-direction: column; justify-content: center; gap: 3px; min-width: 0; }
    .track-title-text {
      font-family: 'Orbitron', sans-serif; font-weight: 700;
      font-size: 0.9rem; color: var(--lime);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .track-meta-text { font-family: 'Courier Prime', monospace; font-size: 0.48rem; color: var(--ink-dim); letter-spacing: 0.12em; text-transform: uppercase; }
    .track-dur { display: flex; align-items: center; padding: 13px 14px; font-family: 'Courier Prime', monospace; font-size: 0.64rem; color: var(--ink-dim); border-left: 1px solid var(--border); white-space: nowrap; font-variant-numeric: tabular-nums; }

    /* Remix row */
    .remix-row { background: var(--green-faint); border-top: 1px dashed var(--green-border); cursor: pointer; position: relative; }
    .remix-row:hover { background: var(--lime-faint); }
    .remix-row:focus-within { outline: 2px solid var(--focus-ring); outline-offset: -2px; }
    .remix-file-input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; z-index: 2; }
    .remix-icon-cell { display: flex; align-items: center; justify-content: center; padding: 12px 0; border-right: 1px dashed var(--green-border); min-width: 52px; }
    .remix-icon-cell img { width: 24px; height: 24px; object-fit: contain; opacity: 0.5; filter: hue-rotate(60deg) saturate(2); }
    .remix-info { padding: 11px 16px; display: flex; flex-direction: column; justify-content: center; gap: 3px; min-width: 0; }
    .remix-title { font-family: 'Orbitron', sans-serif; font-weight: 400; font-size: 0.8rem; color: var(--lime-dim); letter-spacing: 0.06em; }
    .remix-sub { font-family: 'Courier Prime', monospace; font-size: 0.46rem; color: var(--ink-dim); letter-spacing: 0.12em; text-transform: uppercase; }
    .remix-status { display: flex; align-items: center; padding: 11px 14px; font-family: 'Courier Prime', monospace; font-size: 0.54rem; color: var(--lime-dim); border-left: 1px dashed var(--green-border); white-space: nowrap; letter-spacing: 0.1em; text-transform: uppercase; }
    .upload-toast { display: none; padding: 8px 20px; font-family: 'Courier Prime', monospace; font-size: 0.52rem; color: var(--ink-dim); letter-spacing: 0.06em; background: var(--lime-faint); border-top: 1px solid var(--border); }
    .upload-toast.show { display: block; }

    /* Share strip */
    .share-strip { display: flex; justify-content: center; align-items: center; gap: 20px; margin: 20px 0 10px; }
    .share-btn {
      display: flex; align-items: center; justify-content: center;
      width: 34px; height: 34px;
      background: transparent; border: 1px solid var(--border-mid);
      color: var(--ink-dim); cursor: pointer;
      transition: border-color 140ms, color 140ms, background 140ms, box-shadow 140ms;
      padding: 0; position: relative;
    }
    .share-btn:hover { border-color: var(--lime); color: var(--lime); background: var(--lime-faint); box-shadow: 0 0 8px var(--lime-border); }
    .share-btn:active { transform: translate(1px,1px); }
    .share-btn svg { width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }
    .share-btn.copied { border-color: var(--lime); color: var(--lime); }
    .share-btn.copied::after {
      content: "Copied"; position: absolute; bottom: -22px; left: 50%; transform: translateX(-50%);
      font-family: 'Courier Prime', monospace; font-size: 0.44rem; letter-spacing: 0.1em;
      color: var(--lime); white-space: nowrap; pointer-events: none;
    }
    .share-btn.hidden { display: none; }

    /* Footer */
    .page-footer { margin-top: 10px; text-align: center; width: 100%; }
    .page-footer a {
      font-family: 'Courier Prime', monospace; font-size: 0.6rem;
      letter-spacing: 0.28em; text-transform: uppercase; color: var(--ink-dim);
      text-decoration: none; border-bottom: 1px solid var(--border);
      padding-bottom: 2px; transition: color 140ms, border-color 140ms;
    }
    .page-footer a:hover { color: var(--lime); border-color: var(--lime-border); }

    /* Mobile */
    @media (max-width: 640px) {
      .page-shell { padding: 16px 12px 48px; }
      .main-grid { grid-template-columns: 1fr; }
      .col-art { border-right: none; border-bottom: 1px solid var(--border-mid); }
      .col-player { padding: 16px; }
      .kbd-row { display: none; }
      .track-btn, .remix-row { grid-template-columns: 44px 1fr auto; }
      .track-num, .remix-icon-cell { min-width: 44px; }
      .playlist-header { border-left-width: 2px; }
    }

    audio { position: fixed; left: -9999px; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  </style>
</head>

<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <main class="page-shell" id="main-content">
    <div class="inner">

      <header class="masthead" role="banner">
        <p class="masthead-eyebrow" id="mastheadEyebrow">index_album · Pat Bɇɇ</p>
        <div class="masthead-titles">
          <h1 class="masthead-title" id="mastheadTitle">PFuture33</h1>
        </div>
        <p class="masthead-sub">Pat Bɇɇ &nbsp;·&nbsp; index_album</p>
      </header>

      <div class="main-grid">

        <div class="col-art">
          <div class="art-wrap" id="artWrap">
            <img id="albumArtImg" src="" alt="PFuture33 by Pat Bɇɇ — cover art" />
          </div>
        </div>

        <div class="col-player">
          <div aria-live="polite" aria-atomic="true">
            <p class="np-label">Now Playing</p>
            <p class="np-title" id="npTitle">PFuture33</p>
            <div class="np-meta">
              <span class="live-dot" id="liveDot" aria-hidden="true"></span>
              <span class="fmt-dot" id="fmtDot" aria-hidden="true" title="Format indicator"></span>
