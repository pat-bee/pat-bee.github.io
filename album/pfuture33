            <button class="ctrl-btn" id="nextBtn" type="button" aria-label="Next track">Next →</button>
            <button class="ctrl-btn repeat-btn" id="repeatBtn" type="button"
              data-mode="off" aria-label="Repeat mode: off. Press to cycle." aria-pressed="false">↺ Repeat: Off</button>
