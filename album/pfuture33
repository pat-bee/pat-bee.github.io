      </section>

      <div class="share-strip" id="shareStrip" aria-label="Share this page">
        <button class="share-btn" id="btnNativeShare" aria-label="Share this page" title="Share">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 12v7a1 1 0 001 1h14a1 1 0 001-1v-7"/>
