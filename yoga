<head>
<style>
body {
  margin: 0;
  overflow: hidden;
  font-family: system-ui;
}

.viewport {
  height: 100vh;
  overflow: hidden;
  position: relative;
}

.text {
  position: absolute;
  width: 100%;
  padding: 40px;
  animation: scroll 2400s linear forwards; /* 40 minutes = 2400 seconds */
}

@keyframes scroll {
  from { transform: translateY(0); }
  to   { transform: translateY(-100%); }
}
</style>
</head>

